# AQ Data Pulse — TestFlight automation (Cyrano pattern)
# Usage: cd AQDataPulse && bundle exec fastlane beta

default_platform(:ios)

def api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_filepath: ENV.fetch("ASC_KEY_PATH"),
    duration: 1200,
    in_house: false
  )
end

platform :ios do
  desc "Verify App Store Connect API key"
  lane :verify_api do
    require "spaceship"
    Spaceship::ConnectAPI.token = api_key
    apps = Spaceship::ConnectAPI::App.all
    UI.success("API key OK — #{apps.length} app(s) visible")
  end

  desc "Archive only (CI build-only mode)"
  lane :build_only do
    api_key_param = api_key
    sync_code_signing(
      type: "appstore",
      readonly: true,
      api_key: api_key_param
    )
    build_app(
      project: "AQDataPulse.xcodeproj",
      scheme: "AQDataPulse",
      export_method: "app-store",
      output_directory: "build/ipa"
    )
  end

  desc "Archive and upload to TestFlight"
  lane :beta do
    api_key_param = api_key
    sync_code_signing(
      type: "appstore",
      readonly: true,
      api_key: api_key_param
    )
    increment_build_number(
      build_number: ENV["FL_BUILD_NUMBER"],
      xcodeproj: "AQDataPulse.xcodeproj"
    ) if ENV["FL_BUILD_NUMBER"]
    build_app(
      project: "AQDataPulse.xcodeproj",
      scheme: "AQDataPulse",
      export_method: "app-store",
      output_directory: "build/ipa"
    )
    upload_to_testflight(
      api_key: api_key_param,
      skip_waiting_for_build_processing: true
    )
  end
end
